{
  "name": "@erickreis/img-opt",
  "version": "0.1.3",
  "description": "Simple CLI to optimize SVG and PNG assets in web applications.",
  "keywords": [
    "assets",
    "cli",
    "images",
    "optimizer",
    "png",
    "svg",
    "webp"
  ],
  "license": "MIT",
  "bin": {
    "@erickreis/img-opt": "./dist/cli.js",
    "img-opt": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outfile ./dist/cli.js --target node --format esm --external sharp --external svgo",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test",
    "test": "bun test",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "sharp": "^0.34.4",
    "svgo": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260330.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  },
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "bun@1.3.11"
}
